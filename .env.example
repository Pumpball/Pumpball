# ============================================
# Pump.fun SOL Lottery Bot - Config
# ============================================
# Copy this file to .env and fill in your values

# Your wallet's base58-encoded private key (the creator wallet)
PRIVATE_KEY=your_base58_private_key_here

# Your token's contract address (mint)
TOKEN_MINT=your_token_ca_here

# Helius API key (free tier works, supports comma-separated for rotation)
HELIUS_API_KEY=your_helius_api_key_here

# Supabase PostgreSQL connection string
# Find it in: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=your_supabase_connection_string_here

# ============================================
# Optional settings (defaults shown)
# ============================================

# How often to collect fees (minutes)
COLLECTION_INTERVAL_MINUTES=5

# How often to run the hourly draw (minutes)
HOURLY_DRAW_MINUTES=60

# How often to run the jackpot draw (minutes, 1440 = 24h)
JACKPOT_DRAW_MINUTES=1440

# Token decimals (pump.fun default is 6)
TOKEN_DECIMALS=6

# Minimum token holding to qualify (human-readable, 100000 = 100k tokens)
MIN_HOLDING=100000

# How many tokens = 1 lottery entry (human-readable)
ENTRIES_PER_TOKENS=100000

# SOL to always keep in wallet as gas reserve
SOL_RESERVE=0.05

# Percentage of collected fees to hourly pot (remainder goes to jackpot)
# 50 = 50/50 split, 40 = 40% hourly / 60% jackpot, etc.
HOURLY_SPLIT_PCT=50

# Fee claim pool: "pump", "pump-swap", or "both"
CLAIM_POOL=both

# Jupiter API key for SOL price lookups (free at https://portal.jup.ag)
# Optional — falls back to DexScreener if not set
JUPITER_API_KEY=
